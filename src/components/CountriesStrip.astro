---
import { countries } from "@/site.config";
---

<section class="countries">
  <div class="container countries__inner">
    <p class="countries__label">International experience</p>
    <div class="countries__list">
      {
        countries.map((c) => (
          <span class="countries__item" title={c.name}>
            <span class="countries__code">{c.code}</span>
            <span class="countries__name">{c.name}</span>
          </span>
        ))
      }
    </div>
  </div>
</section>

<style>
  .countries {
    padding: 2.2rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: #102b2e;
  }

  .countries__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 2rem;
  }

  .countries__label {
    margin: 0;
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.68);
  }

  .countries__list {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .countries__item {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .countries__code {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: #8ee0d4;
  }

  .countries__name {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.76);
  }
</style>
