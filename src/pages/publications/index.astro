---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { social } from "@/site.config";

const publications = (await getCollection("publications")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Publications" description="Research publications by Manuela Runge.">
  <div class="page-header">
    <div class="container">
      <h1>Publications</h1>
      <p>
        Research on malaria modeling, subnational tailoring, and infectious disease
        epidemiology. Also on <a href={social.googlescholar}>Google Scholar</a>.
      </p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="pub-list">
        {
          await Promise.all(
            publications.map(async (pub) => {
              const { Content } = await render(pub);
              return (
                <article class="pub-item" id={pub.id}>
                  <div class="pub-item__meta">
                    <time datetime={pub.data.date.toISOString()}>
                      {pub.data.date.getFullYear()}
                    </time>
                    {pub.data.venue && <span>{pub.data.venue}</span>}
                  </div>
                  <h2>{pub.data.title}</h2>
                  <div class="pub-item__body prose">
                    <Content />
                  </div>
                  {pub.data.paperurl && (
                    <p class="pub-item__link">
                      <a href={pub.data.paperurl} target="_blank" rel="noopener noreferrer">
                        Read paper →
                      </a>
                    </p>
                  )}
                  {pub.data.citation && (
                    <details class="pub-item__citation">
                      <summary>Citation</summary>
                      <p>{pub.data.citation}</p>
                    </details>
                  )}
                </article>
              );
            })
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .pub-list {
    display: grid;
    gap: 1.25rem;
  }

  .pub-item {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 1.5rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-card);
    box-shadow: 0 8px 26px rgba(24, 46, 56, 0.05);
  }

  .pub-item:last-child {
    border-bottom: 1px solid var(--border);
  }

  .pub-item__meta {
    display: grid;
    align-content: start;
    gap: 0.45rem;
    margin-bottom: 0.75rem;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent);
  }

  .pub-item h2,
  .pub-item__body,
  .pub-item__link,
  .pub-item__citation {
    grid-column: 2;
  }

  .pub-item__meta time {
    font-family: var(--font-display);
    font-size: 2.15rem;
    line-height: 1;
    color: var(--coral);
  }

  .pub-item h2 {
    margin: 0 0 1rem;
    font-size: 1.35rem;
  }

  .pub-item__body :global(p) {
    margin-top: 0;
  }

  .pub-item__link {
    margin: 1rem 0 0;
  }

  .pub-item__citation {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .pub-item__citation summary {
    cursor: pointer;
    color: var(--text-muted);
  }

  @media (max-width: 720px) {
    .pub-item {
      grid-template-columns: 1fr;
    }

    .pub-item__meta {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
    }

    .pub-item h2,
    .pub-item__body,
    .pub-item__link,
    .pub-item__citation {
      grid-column: 1;
    }
  }
</style>
